CONVEX_URL=https://your-dev-deployment.convex.cloud
CONVEX_SITE_URL=https://your-dev-deployment.convex.site
INGEST_SHARED_SECRET=replace-me
COLLECTOR_NAME=btc-rtds-collector
COLLECT_CRYPTO_ASSETS=btc,eth
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_MARKET_WSS=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_RTDS_WSS=wss://ws-live-data.polymarket.com
COLLECTOR_BATCH_MS=1000
COLLECTOR_HEARTBEAT_MS=30000
RTDS_HEARTBEAT_MS=5000
RTDS_CONNECT_TIMEOUT_MS=10000
MARKET_WS_HEARTBEAT_MS=10000
MARKET_WS_CONNECT_TIMEOUT_MS=10000
ACTIVE_MARKETS_REFRESH_MS=15000
# Replay UI supports sparse capture cadences such as 5000ms without blank charts.
SNAPSHOT_POLL_MS=1000
CLOB_BATCH_SIZE=500
CLOB_REQUEST_TIMEOUT_MS=10000
CLOB_MAX_ATTEMPTS=3
CLOB_RETRY_BASE_MS=250
ENABLE_BINANCE_CONTEXT=false
ENABLE_MARKET_WS=true
PERSIST_MARKET_RAW_EVENTS=true
MARKET_WS_PRIMARY=false
MARKET_WS_PARITY_TOLERANCE=0.03
LOG_LEVEL=info
